@model ECommerce.Models.Category
@{
    ViewData["Title"] = "Kategori Düzenle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/admin/kategoriler" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0">Kategori Düzenle</h4>
        <p class="text-muted mb-0 small">@Model.Name kategorisini düzenleyin.</p>
    </div>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="form-card">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <input asp-for="CreatedAt" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <div class="form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                        <label asp-for="IsActive" class="form-check-label">Aktif</label>
                    </div>
                    <div class="text-muted small mt-1">Kategoriyi pasife alırsanız bu kategorideki ürünler görünmez olabilir.</div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-circle me-2"></i>Değişiklikleri Kaydet
                    </button>
                    <a href="/admin/kategoriler" class="btn btn-outline-secondary">İptal</a>
                </div>
            </form>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card border-0 rounded-3 bg-light">
            <div class="card-body p-4">
                <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle text-primary me-2"></i>Kategori Bilgileri</h6>
                <dl class="row text-muted small mb-0">
                    <dt class="col-6">Kategori ID:</dt>
                    <dd class="col-6">#@Model.Id</dd>
                    <dt class="col-6">Oluşturulma:</dt>
                    <dd class="col-6">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
