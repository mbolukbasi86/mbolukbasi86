@model ECommerce.Models.Category
@{
    ViewData["Title"] = "Yeni Kategori Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/admin/kategoriler" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0">Yeni Kategori Ekle</h4>
        <p class="text-muted mb-0 small">Yeni bir ürün kategorisi oluşturun.</p>
    </div>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="form-card">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control" placeholder="Örn: Elektronik, Giyim..." />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"
                              placeholder="Kategori hakkında kısa bir açıklama yazın..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <div class="form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" checked />
                        <label asp-for="IsActive" class="form-check-label">Aktif</label>
                    </div>
                    <div class="text-muted small mt-1">Aktif kategoriler ürün eklemek için kullanılabilir.</div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4">
                        <i class="bi bi-check-circle me-2"></i>Kategori Ekle
                    </button>
                    <a href="/admin/kategoriler" class="btn btn-outline-secondary">İptal</a>
                </div>
            </form>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card border-0 rounded-3 bg-light">
            <div class="card-body p-4">
                <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle text-primary me-2"></i>İpuçları</h6>
                <ul class="list-unstyled text-muted small mb-0">
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Kategori adı benzersiz olmalıdır.</li>
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Açıklama alanı isteğe bağlıdır.</li>
                    <li class="mb-2"><i class="bi bi-check2 text-success me-2"></i>Pasif kategorilere yeni ürün eklenemez.</li>
                    <li><i class="bi bi-check2 text-success me-2"></i>Ürün içeren kategoriler silinemez.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
