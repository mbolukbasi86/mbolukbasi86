@model ECommerceAdmin.Models.Product
@{
    ViewData["Title"] = "Ürün Düzenle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/admin/urunler" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="fw-bold mb-0">Ürün Düzenle</h4>
        <p class="text-muted mb-0 small">@Model.Name ürününü düzenleyin.</p>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="form-card">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <input asp-for="CreatedAt" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Price" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <input asp-for="Price" class="form-control" type="number" step="0.01" min="0.01" />
                            <span class="input-group-text">₺</span>
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="StockQuantity" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <input asp-for="StockQuantity" class="form-control" type="number" min="0" />
                            <span class="input-group-text">adet</span>
                        </div>
                        <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="CategoryId" class="form-label fw-semibold"></label>
                        <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                            <option value="">-- Kategori Seçin --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="ImageUrl" class="form-label fw-semibold"></label>
                        <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                        <div class="form-text">Ürün görselinin tam URL adresi.</div>
                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="IsActive" class="form-check-label fw-semibold">Aktif</label>
                        </div>
                        <div class="text-muted small mt-1">Aktif ürünler mağazada görüntülenir.</div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-circle me-2"></i>Değişiklikleri Kaydet
                    </button>
                    <a href="/admin/urunler" class="btn btn-outline-secondary">İptal</a>
                </div>
            </form>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 rounded-3 bg-light">
            <div class="card-body p-4">
                <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle text-primary me-2"></i>Ürün Bilgileri</h6>
                <dl class="row text-muted small mb-0">
                    <dt class="col-5">Ürün ID:</dt>
                    <dd class="col-7">#@Model.Id</dd>
                    <dt class="col-5">Eklenme:</dt>
                    <dd class="col-7">@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
                    <dt class="col-5">Son Güncelleme:</dt>
                    <dd class="col-7">@Model.UpdatedAt.ToString("dd.MM.yyyy HH:mm")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
