@model IEnumerable<BootStrapECommerce.Models.Product>

@{
    ViewData["Title"] = "Ana Sayfa";
}

<!-- Hero Section -->
<div class="hero-section text-center mb-5">
    <div class="container">
        <h1 class="display-4 fw-bold">BootStrap E-Ticaret'e Hoş Geldiniz!</h1>
        <p class="lead mb-4">En güncel ürünleri keşfedin ve en iyi fiyatlarla alışveriş yapın.</p>
        <a asp-controller="Product" asp-action="Index" class="btn btn-light btn-lg px-4">
            Tüm Ürünleri Gör
        </a>
    </div>
</div>

<!-- Featured Products -->
<div class="container mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Öne Çıkan Ürünler</h2>
        <a asp-controller="Product" asp-action="Index" class="btn btn-outline-dark">Tümünü Gör →</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Henüz ürün bulunmuyor.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4">
            @foreach (var product in Model)
            {
                <div class="col">
                    <div class="card h-100 product-card border-0 shadow-sm">
                        <!-- Product Image: uses DisplayImagePath which falls back to no-image.png -->
                        <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.Id">
                            <div class="product-img-wrapper">
                                <img src="@product.DisplayImagePath"
                                     alt="@product.Name"
                                     onerror="this.src='/images/products/no-image.png'" />
                            </div>
                        </a>
                        <div class="card-body d-flex flex-column">
                            <span class="badge bg-secondary mb-2 align-self-start">@product.Category</span>
                            <h5 class="card-title">
                                <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.Id"
                                   class="text-decoration-none text-dark">@product.Name</a>
                            </h5>
                            <p class="card-text text-muted small flex-grow-1">
                                @(product.Description?.Length > 80 ? product.Description.Substring(0, 80) + "..." : product.Description)
                            </p>
                            <div class="mt-2">
                                @if (product.OldPrice.HasValue)
                                {
                                    <span class="price-old me-2">@product.OldPrice.Value.ToString("C", new System.Globalization.CultureInfo("tr-TR"))</span>
                                }
                                <span class="price-new">@product.Price.ToString("C", new System.Globalization.CultureInfo("tr-TR"))</span>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 pb-3">
                            <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.Id"
                               class="btn btn-dark w-100">Ürünü İncele</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
