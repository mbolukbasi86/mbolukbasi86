@model IEnumerable<ECommerceAdmin.Models.Category>
@{
    ViewData["Title"] = "Kategoriler";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Kategoriler</h4>
        <p class="text-muted mb-0">@Model.Count() kategori listeleniyor.</p>
    </div>
    <a href="/admin/kategoriler/ekle" class="btn btn-success d-flex align-items-center gap-2">
        <i class="bi bi-plus-circle"></i> Yeni Kategori
    </a>
</div>

<div class="admin-table">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Kategori Adı</th>
                    <th>Açıklama</th>
                    <th>Ürün Sayısı</th>
                    <th>Durum</th>
                    <th>Oluşturulma</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                            Henüz kategori eklenmemiş.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var category in Model)
                    {
                        <tr>
                            <td class="text-muted small">@category.Id</td>
                            <td class="fw-semibold">@category.Name</td>
                            <td class="text-muted">@(category.Description ?? "-")</td>
                            <td>
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
                                    @category.Products.Count ürün
                                </span>
                            </td>
                            <td>
                                @if (category.IsActive)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Aktif</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary"><i class="bi bi-x-circle me-1"></i>Pasif</span>
                                }
                            </td>
                            <td class="text-muted small">@category.CreatedAt.ToString("dd.MM.yyyy")</td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a href="/admin/kategoriler/duzenle/@category.Id" class="btn btn-sm btn-outline-primary" title="Düzenle">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    @if (!category.Products.Any())
                                    {
                                        <form action="/admin/kategoriler/sil/@category.Id" method="post" style="display:inline"
                                              onsubmit="return confirm('@category.Name kategorisini silmek istediğinize emin misiniz?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-secondary" disabled title="Bu kategoriye ait ürünler var">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
