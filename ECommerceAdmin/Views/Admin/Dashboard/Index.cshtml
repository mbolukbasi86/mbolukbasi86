@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Dashboard</h4>
        <p class="text-muted mb-0">ECommerce admin panelinize hoş geldiniz.</p>
    </div>
    <div class="text-muted small">
        <i class="bi bi-calendar3 me-1"></i>@DateTime.Now.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))
    </div>
</div>

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                    <i class="bi bi-box-seam"></i>
                </div>
                <div>
                    <div class="text-muted small">Toplam Ürün</div>
                    <div class="fs-4 fw-bold">@ViewBag.TotalProducts</div>
                    <div class="text-success small"><i class="bi bi-check-circle me-1"></i>@ViewBag.ActiveProducts aktif</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-success bg-opacity-10 text-success">
                    <i class="bi bi-tags"></i>
                </div>
                <div>
                    <div class="text-muted small">Toplam Kategori</div>
                    <div class="fs-4 fw-bold">@ViewBag.TotalCategories</div>
                    <div class="text-success small"><i class="bi bi-check-circle me-1"></i>@ViewBag.ActiveCategories aktif</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <div>
                    <div class="text-muted small">Düşük Stok</div>
                    <div class="fs-4 fw-bold">@ViewBag.LowStockProducts</div>
                    <div class="text-warning small">10'dan az stok</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="stat-icon bg-info bg-opacity-10 text-info">
                    <i class="bi bi-currency-dollar"></i>
                </div>
                <div>
                    <div class="text-muted small">Stok Değeri</div>
                    <div class="fs-5 fw-bold">@ViewBag.TotalStockValue.ToString("N2") ₺</div>
                    <div class="text-info small">Aktif ürünler</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions + Recent Products -->
<div class="row g-3">
    <div class="col-lg-4">
        <div class="card border-0 rounded-3" style="box-shadow: 0 2px 8px rgba(0,0,0,0.06);">
            <div class="card-header bg-transparent border-bottom fw-semibold">
                <i class="bi bi-lightning-charge text-warning me-2"></i>Hızlı İşlemler
            </div>
            <div class="card-body d-flex flex-column gap-2 p-3">
                <a href="/admin/urunler/ekle" class="btn btn-primary w-100 text-start d-flex align-items-center gap-2">
                    <i class="bi bi-plus-circle"></i> Yeni Ürün Ekle
                </a>
                <a href="/admin/kategoriler/ekle" class="btn btn-success w-100 text-start d-flex align-items-center gap-2">
                    <i class="bi bi-plus-circle"></i> Yeni Kategori Ekle
                </a>
                <a href="/admin/urunler" class="btn btn-outline-secondary w-100 text-start d-flex align-items-center gap-2">
                    <i class="bi bi-list-ul"></i> Tüm Ürünleri Gör
                </a>
                <a href="/admin/kategoriler" class="btn btn-outline-secondary w-100 text-start d-flex align-items-center gap-2">
                    <i class="bi bi-grid"></i> Tüm Kategorileri Gör
                </a>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="admin-table">
            <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom">
                <h6 class="mb-0 fw-semibold"><i class="bi bi-clock-history me-2 text-muted"></i>Son Eklenen Ürünler</h6>
                <a href="/admin/urunler" class="btn btn-sm btn-outline-primary">Tümünü Gör</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Ürün Adı</th>
                            <th>Kategori</th>
                            <th>Fiyat</th>
                            <th>Stok</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in ViewBag.RecentProducts)
                        {
                            <tr>
                                <td class="fw-medium">@product.Name</td>
                                <td><span class="badge bg-light text-dark border">@product.Category?.Name</span></td>
                                <td class="fw-semibold text-primary">@product.Price.ToString("N2") ₺</td>
                                <td>
                                    <span class="badge @(product.StockQuantity < 10 ? "badge-stock-low" : "badge-stock-ok")">
                                        @product.StockQuantity adet
                                    </span>
                                </td>
                                <td>
                                    @if (product.IsActive)
                                    {
                                        <span class="badge bg-success">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Pasif</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
